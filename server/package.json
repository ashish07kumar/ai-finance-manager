{
  "name": "finance-tracker-backend",
  "version": "1.0.0",
  "description": "SaaS Personal Finance Tracker Backend with Node.js, Express, and MongoDB",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "smoke": "node -e \"require('./src/app'); console.log('app-load-ok')\"",
    "worker": "node src/workers/index.js",
    "worker:recurring": "node src/workers/recurring.worker.js",
    "worker:notifications": "node src/workers/notifications.worker.js",
    "worker:reports": "node src/workers/reports.worker.js",
    "worker:analytics": "node src/workers/analytics.worker.js"
  },
  "keywords": [
    "finance",
    "tracker",
    "saas",
    "backend",
    "mongodb",
    "express"
  ],
  "author": "ashish kumar",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.0.0",
    "dotenv": "^16.3.1",
    "express-rate-limit": "^7.5.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "cookie-parser": "^1.4.6",
    "express-validator": "^7.0.1",
    "joi": "^17.13.3",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.15",
    "ioredis": "^5.4.1",
    "bullmq": "^5.10.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "socket.io": "^4.8.0",
    "winston": "^3.13.1",
    "json2csv": "^6.0.0-alpha.2",
    "pdfkit": "^0.15.0",
    "multer": "^1.4.5-lts.1",
    "cloudinary": "^2.5.1",
    "streamifier": "^0.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
